# MiniMax API key — sign up at https://www.minimax.io
# Required for the mnemonic_image workflow (text + image generation)
MINIMAX_API_KEY=your_minimax_key_here

# Anki profile name (optional — auto-detects the first profile if not set)
# Run `ls ~/Library/Application\ Support/Anki2/` to see your profiles
# ANKI_PROFILE=Abu

# Override Anki's bundled Python path (optional — default works on macOS)
# ANKI_PYTHON=/Library/Application\ Support/AnkiProgramFiles/.venv/bin/python3.13
